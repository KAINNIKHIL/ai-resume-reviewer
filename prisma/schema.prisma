generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  image         String?

  emailVerified DateTime?

  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Resume {
  id            String   @id @default(cuid())
  title         String
  fileUrl       String
  extractedText String?
  analysis      Analysis?
  jobMatches JobMatch[]
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  optimization ResumeOptimization?
  coverLetters CoverLetter[]

  createdAt     DateTime @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Analysis {
  id            String   @id @default(cuid())
  score         Int
  remark        String?
  strengths     Json
  weaknesses    Json
  missingSkills Json
  suggestions   Json

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id])

  createdAt DateTime @default(now())
}

model JobMatch {
  id               String   @id @default(cuid())

  jobDescription   String

  matchScore       Int

  matchedSkills    Json

  missingKeywords  Json

  suggestions      Json

  resumeId         String
  resume           Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ResumeOptimization {
  id String @id @default(cuid())

  originalSummary String?
  optimizedSummary String?

  originalExperience Json?
  optimizedExperience Json?

  originalSkills Json?
  optimizedSkills Json?

  optimizedResume String

  aiSummary Json?

  resumeId String @unique
  resume Resume @relation(fields: [resumeId], references: [id])

  createdAt DateTime @default(now())
}

model CoverLetter {
  id          String   @id @default(cuid())

  companyName String?
  jobTitle    String?

  jobDescription String

  content String

  resumeId String
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}