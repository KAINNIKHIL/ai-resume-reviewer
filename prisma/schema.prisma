generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?

  resumes   Resume[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id            String   @id @default(cuid())
  title         String
  fileUrl       String
  extractedText String?

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
}